@model IEnumerable<AppMvcTeste.Models.Produto>
<h2>Lista de Produtos (Teste)</h2>
<span style="color: green; font-size: 1rem; padding: 12px; border-radius: 12px; background-color: yellow; margin: 2px;">Deploy foi realizado com sucesso!!!</span>
<p><a href="/Produtos/Criar" class="btn btn-primary">Inserir Novo Produto</a></p>

<table class="table">
    <thead>
        <tr><th>ID</th><th>Nome</th><th>Preço</th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nome</td>
                <td>@item.Preco.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>